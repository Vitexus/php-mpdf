#!/usr/bin/make -f

export DH_VERBOSE = 1
export COMPOSER_HOME = /tmp/composer-home

PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell dpkg-parsechangelog -S Source)

%:
	dh $@

override_dh_auto_clean:
	dh_auto_clean
	rm -rf vendor/

override_dh_install:
	dh_install
	sed -i "s|: 'unknown'|: '$(PKG_SOURCE)'|" \
		debian/php-mpdf/usr/share/php/mpdf/autoload.php
	sed -i "s|: '0.0.0'|: '$(PKG_VERSION)'|" \
		debian/php-mpdf/usr/share/php/mpdf/autoload.php
